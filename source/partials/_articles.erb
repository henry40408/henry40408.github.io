<section class="article list">
  <% articles.each do |article| %>
    <article>
      <header>
        <h3>
          <span><%= link_to article.title, article.url %></span>
          <small><%= article.date.strftime "%Y-%m-%d %H:%M" %></small>
        </h3>
        <div><%= partial "partials/tags", locals: { tags: article.tags } %></div>
      </header>
      <section>
        <%= article.summary %>
      </section>
    </article>
  <% end %>
</section>

<h2>寫前端的後端工程師</h2>

<section class="article list">
  <% blog.articles.each do |article| %>
    <div class="article">
      <span><%= link_to article.title, article.url %></span>
      <span>//</span>
      <span class="date"><%= article.date.strftime "%Y-%m-%d %H:%M:%S" %></span>
    </div>
  <% end %>
</section>

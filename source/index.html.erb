<h1>寫前端的後端工程師</h1>

<section class="article list">
  <% blog.articles.each do |article| %>
    <div class="article">
      <span><%= link_to article.title, article.url %></span>
      <small class="date"><%= article.date.strftime "%Y-%m-%d %H:%M:%S" %></small>
    </div>
  <% end %>
</section>
